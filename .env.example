CRON_SECRET=replace-with-a-long-random-string

X_BEARER_TOKEN=your-x-bearer-token
X_SEARCH_QUERY=(AI OR OpenAI OR Anthropic OR Google OR Apple OR Meta OR Microsoft OR Vercel OR React OR Next.js OR TypeScript OR startup) lang:en -is:retweet -is:reply
X_MAX_RESULTS=30

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

GITHUB_TOKEN=your-github-token
GITHUB_REPO_OWNER=your-github-user-or-org
GITHUB_REPO_NAME=your-repository-name
GITHUB_BASE_BRANCH=main
GITHUB_DRAFTS_PATH=content/blog/drafts
GITHUB_REPOSITORY_URL=https://github.com/your-github-user-or-org/your-repository-name

NEWS_DIGEST_AUTHOR=Adriano Almeida
NEWS_DIGEST_TIMEZONE=America/Sao_Paulo
NEWS_DIGEST_MAX_ITEMS=7
NEWS_DIGEST_MIN_SCORE=2
